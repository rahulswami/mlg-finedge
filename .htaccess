# ----------------------------------------------------------------------
# | Security & Performance Tuning for www.mlgfinedge.com                 |
# ----------------------------------------------------------------------

# 1. Prevent Directory Browsing
Options -Indexes

# 2. Disable Server Signature
ServerSignature Off

# 3. Security Headers
<IfModule mod_headers.c>
    # Protect against Clickjacking
    Header set X-Frame-Options "SAMEORIGIN"
    # Protect against MIME Sniffing
    Header set X-Content-Type-Options "nosniff"
    # Enable XSS Filter in browsers
    Header set X-XSS-Protection "1; mode=block"
    # Strict Transport Security (HSTS)
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    # Referrer Policy
    Header set Referrer-Policy "no-referrer-when-downgrade"
</IfModule>

# 4. Block Sensitive Files
<FilesMatch "^\.env|composer\.(json|lock)|package\.(json|lock)|config\.json|test.*|artisan|database\.sqlite|\.git.*|.*\.sql|.*\.log|.*\.sh|.*\.md$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# 5. Core Rewrite Rules
<IfModule mod_rewrite.c>
    RewriteEngine On

    # A. Force HTTPS & WWW (https://www.mlgfinedge.com) for production
    # Redirect non-www to www
    RewriteCond %{HTTP_HOST} ^mlgfinedge\.com$ [NC]
    RewriteRule ^(.*)$ https://www.mlgfinedge.com/$1 [L,R=301]
    
    # Redirect HTTP to HTTPS
    RewriteCond %{HTTPS} off
    RewriteCond %{HTTP_HOST} ^(www\.)?mlgfinedge\.com$ [NC]
    RewriteRule ^(.*)$ https://www.mlgfinedge.com/$1 [L,R=301]

    # B. Prevent script injection / common exploits
    RewriteCond %{QUERY_STRING} (<|%3C).*script.*(>|%3E) [NC,OR]
    RewriteCond %{QUERY_STRING} GLOBALS(=|\[|\%[0-9A-Z]{0,2}) [OR]
    RewriteCond %{QUERY_STRING} _REQUEST(=|\[|\%[0-9A-Z]{0,2})
    RewriteRule ^(.*)$ - [F,L]

    # C. Rewrite Root Requests to /public
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
